/* ───────────────────────────── UPLOAD PAGE ───────────────────────────── */
function showUploadPage() {
  const app = document.getElementById('app');
  app.innerHTML = `
    <div class="logo">Tmp<span>Drop</span></div>
    <p class="tagline">Partage temporaire · Auto-suppression 24h</p>
    <div class="card">
      <div class="drop-zone" id="dropZone">
        <input type="file" id="fileInput">
        <div class="drop-icon">📁</div>
        <div class="drop-text" style="margin-bottom:0.5rem;">Glisse un fichier ici ou appuie pour choisir</div>
        <button class="btn btn-outline" id="chooseFileBtn" type="button" style="width:auto;display:inline-block;padding:0.5rem 1.2rem;font-size:0.85rem;">Choisir un fichier</button>
        <div class="file-info" id="fileInfo">
          <span class="name" id="fileName"></span>
          <span class="size" id="fileSize"></span>
        </div>
      </div>
      <div id="statusMsg" style="display:none;font-size:0.85rem;margin-bottom:0.8rem;text-align:center;"></div>
      <div class="progress-bar" id="progressBar"><div class="progress-fill" id="progressFill"></div></div>
      <button class="btn btn-primary" id="uploadBtn" disabled>Choisissez un fichier</button>
      <div class="result show" id="result">
        <div id="successMsg" style="display:none;margin-bottom:0.8rem;color:var(--gold);font-weight:600;">✅ Fichier partagé !</div>
        <div class="copy-row">
          <a class="link-box" id="shareLink" target="_blank"></a>
          <button class="copy-btn" id="copyBtn">Copier</button>
        </div>
        <div id="uploadShareTiles"></div>
        <button class="btn btn-primary" id="newUploadBtn" style="margin-top:1rem;">📤 Nouvel upload</button>
      </div>
    </div>
    <div class="card" style="text-align:center;font-size:0.85rem;color:var(--text-dim);">
      <div style="margin-bottom:0.3rem;">📤 Fichiers jusqu'à 50 Mo · Gratuit</div>
      <div>⏳ Supprimés automatiquement après 24h</div>
    </div>
    <div class="footer">TmpDrop · <a href="https://ucfzem.github.io/liens/" style="color:var(--text-dim);">ucfzem</a></div>
  `;
  setupUpload();
}


function setupUpload() {
  const dropZone = document.getElementById('dropZone');
  const fileInput = document.getElementById('fileInput');
  const chooseBtn = document.getElementById('chooseFileBtn');
  const fileInfo = document.getElementById('fileInfo');
  const fileName = document.getElementById('fileName');
  const fileSize = document.getElementById('fileSize');
  const uploadBtn = document.getElementById('uploadBtn');
  const progressBar = document.getElementById('progressBar');
  const progressFill = document.getElementById('progressFill');
  const shareLink = document.getElementById('shareLink');
  const copyBtn = document.getElementById('copyBtn');
  const statusEl = document.getElementById('statusMsg');


  var selectedFile = null;

  // Init share tiles with app URL on page load
  var appUrl = window.location.origin + BASE;
  document.getElementById('shareLink').textContent = appUrl;
  document.getElementById('shareLink').href = appUrl;
  document.getElementById('uploadShareTiles').innerHTML = shareTilesHTML(encodeURIComponent(appUrl), appUrl);
  document.getElementById('copyBtn').onclick = function() {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(appUrl).then(function() {
        document.getElementById('copyBtn').textContent = '✅';
        setTimeout(function(){ document.getElementById('copyBtn').textContent = 'Copier'; }, 2000);
      });
    }
  };

  function selectFile(f) {
    if (!f) return;
    if (f.size > 50 * 1024 * 1024) {
      setStatus('Fichier trop volumineux. Maximum : 50 Mo.', true);
      return;
    }
    selectedFile = f;
    fileName.textContent = f.name;
    fileSize.textContent = formatSize(f.size);
    fileInfo.classList.add('show');
    dropZone.classList.add('has-file');
    uploadBtn.disabled = false;
    uploadBtn.textContent = 'Uploader';
    setStatus('');
  }


  function setStatus(msg, isError) {
    statusEl.textContent = msg;
    statusEl.style.display = msg ? 'block' : 'none';
    statusEl.style.color = isError ? '#e74c3c' : 'var(--text-dim)';
  }


  dropZone.addEventListener('click', function(e) {
    if (e.target !== chooseBtn) fileInput.click();
  });
  chooseBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    fileInput.click();
  });
  fileInput.addEventListener('change', function(e) {
    if (this.files && this.files.length) selectFile(this.files[0]);
  });
  dropZone.addEventListener('dragover', function(e) { e.preventDefault(); this.classList.add('dragover'); });
  dropZone.addEventListener('dragleave', function() { this.classList.remove('dragover'); });
  dropZone.addEventListener('drop', function(e) {
    e.preventDefault();
    this.classList.remove('dragover');
    if (e.dataTransfer && e.dataTransfer.files.length) selectFile(e.dataTransfer.files[0]);
  });


  uploadBtn.addEventListener('click', async function() {
    if (!selectedFile) { setStatus('Veuillez sélectionner un fichier.', true); return; }
    this.disabled = true;
    this.textContent = 'Upload en cours...';
    progressBar.classList.add('show');
    progressFill.style.width = '0%';
    setStatus('');


    try {
      var f = selectedFile;
      var ext = f.name.split('.').pop();
      var storagePath = String(Date.now()) + '_' + Math.random().toString(36).slice(2) + '.' + ext;


      var uploadRes = await fetch(SUPABASE_URL + '/storage/v1/object/tmp-files/' + storagePath, {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + ANON_KEY, 'Content-Type': f.type || 'application/octet-stream' },
        body: f,
      });
      if (!uploadRes.ok) throw new Error('Upload échoué (code ' + uploadRes.status + ')');
      progressFill.style.width = '60%';


      var sid = Math.random().toString(36).slice(2,10) + Math.random().toString(36).slice(2,10);
      var fileUrl = SUPABASE_URL + '/storage/v1/object/public/tmp-files/' + storagePath;
      var recordRes = await fetch(SUPABASE_URL + '/rest/v1/uploads', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': ANON_KEY, 'Authorization': 'Bearer ' + ANON_KEY },
        body: JSON.stringify({ file_url: fileUrl, file_name: f.name, file_size: f.size, mime_type: f.type || null, share_id: sid }),
      });
      if (!recordRes.ok) {
        var errText = await recordRes.text().catch(function(){ return ''; });
        throw new Error('Enregistrement échoué: ' + errText);
      }
      progressFill.style.width = '100%';


      var link = window.location.origin + BASE + '?d=' + sid;
      shareLink.textContent = link;
      shareLink.href = link;
      this.style.display = 'none';
      fileInfo.classList.remove('show');
      fileInfo.style.display = 'none';
      document.getElementById('successMsg').style.display = 'block';
      setStatus('');


      var encodedUrl = encodeURIComponent(link);
      document.getElementById('uploadShareTiles').innerHTML = shareTilesHTML(encodedUrl, link);


      // Native share (mobile)
      var nativeBtn = document.getElementById('nativeShareBtn');
      if (navigator.share) {
        nativeBtn.style.display = 'flex';
        nativeBtn.addEventListener('click', function(e) {
          e.preventDefault();
          navigator.share({ title: 'TmpDrop', text: 'Fichier partagé sur TmpDrop', url: link });
        });
      }


      copyBtn.onclick = function() {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(link).then(function() {
            copyBtn.textContent = '✅';
            setTimeout(function(){ copyBtn.textContent = 'Copier'; }, 2000);
          });
        } else {
          var r = document.createRange();
          r.selectNodeContents(shareLink);
          var s = window.getSelection();
          s.removeAllRanges(); s.addRange(r);
          document.execCommand('copy');
          copyBtn.textContent = '✅';
          setTimeout(function(){ copyBtn.textContent = 'Copier'; }, 2000);
        }
      };


      document.getElementById('newUploadBtn').onclick = function() { showUploadPage(); };


    } catch (err) {
      setStatus('Erreur : ' + err.message, true);
      this.disabled = false;
      this.textContent = selectedFile ? 'Uploader' : 'Choisissez un fichier';
      progressBar.classList.remove('show');
    }
  });
}


/* ───────────────────────────── DOWNLOAD PAGE ───────────────────────────── */
async function showDownloadPage(id) {
  const app = document.getElementById('app');
  app.innerHTML = '<div class="logo">Tmp<span>Drop</span></div><p class="tagline" style="text-align:center;">Récupération...</p>';


  try {
    const res = await fetch(SUPABASE_URL + '/rest/v1/uploads?share_id=eq.' + encodeURIComponent(id) + '&select=*', {
      headers: { 'apikey': ANON_KEY, 'Authorization': 'Bearer ' + ANON_KEY },
    });
    if (!res.ok) throw new Error('Erreur serveur');
    const data = await res.json();


    if (!data || data.length === 0) {
      app.innerHTML = `
        <div class="logo">Tmp<span>Drop</span></div>
        <div class="card error-msg">
          <div style="font-size:3rem;margin-bottom:1rem;">🔗</div>
          <div style="font-weight:600;margin-bottom:0.5rem;">Lien invalide ou expiré</div>
          <div style="font-size:0.85rem;color:var(--text-dim);">Les fichiers sont supprimés après 24h.</div>
          <a href="${BASE}" class="btn btn-primary" style="margin-top:1.5rem;">Nouvel upload</a>
        </div>
        <div class="footer">TmpDrop · Propulsé par Supabase</div>
      `;
      return;
    }


    const file = data[0];
    const expires = new Date(file.expires_at);
    const now = new Date();
    const hoursLeft = Math.max(0, Math.floor((expires - now) / 3600000));
    const minutesLeft = Math.max(0, Math.floor(((expires - now) % 3600000) / 60000));


    var pageLink = window.location.href;
    var encodedUrl = encodeURIComponent(pageLink);


    app.innerHTML = `
      <div class="logo">Tmp<span>Drop</span></div>
      <p class="tagline" style="text-align:center;">Fichier disponible</p>
      <div class="card file-card">
        <div class="icon">📄</div>
        <div class="fname">${esc(file.file_name)}</div>
        <div class="finfo">${formatSize(file.file_size)}${file.mime_type ? ' · ' + esc(file.mime_type) : ''}</div>
        <a href="${esc(file.file_url)}" download="${esc(file.file_name)}" class="btn btn-primary">⬇ Télécharger</a>
        <div class="expires">⏳ Expire dans ${hoursLeft}h ${minutesLeft}min</div>
      </div>


      <div class="card">
        <div style="font-size:0.85rem;color:var(--text-dim);margin-bottom:0.6rem;text-align:center;">Partager ce fichier</div>
        <div class="copy-row">
          <a class="link-box" id="dlShareLink" href="${esc(pageLink)}" target="_blank">${esc(pageLink)}</a>
          <button class="copy-btn" id="dlCopyBtn">Copier</button>
        </div>
        <div id="dlShareTiles"></div>
      </div>


      <div class="card" style="text-align:center;">
        <a href="${BASE}" class="btn btn-outline">📤 Partager un fichier</a>
      </div>
      <div class="footer">TmpDrop · Propulsé par Supabase</div>
    `;


    document.getElementById('dlShareTiles').innerHTML = shareTilesHTML(encodedUrl, pageLink);


    // Native share button
    var nativeBtn = document.getElementById('nativeShareBtn');
    if (navigator.share && nativeBtn) {
      nativeBtn.style.display = 'flex';
      nativeBtn.addEventListener('click', function(e) {
        e.preventDefault();
        navigator.share({ title: 'TmpDrop — ' + file.file_name, text: 'Télécharge ce fichier sur TmpDrop', url: pageLink });
      });
    }


    // Copy button
    document.getElementById('dlCopyBtn').onclick = function() {
      var btn = this;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(pageLink).then(function() {
          btn.textContent = '✅';
          setTimeout(function(){ btn.textContent = 'Copier'; }, 2000);
        });
      } else {
        var r = document.createRange();
        r.selectNodeContents(document.getElementById('dlShareLink'));
        var s = window.getSelection();
        s.removeAllRanges(); s.addRange(r);
        document.execCommand('copy');
        btn.textContent = '✅';
        setTimeout(function(){ btn.textContent = 'Copier'; }, 2000);
      }
    };


  } catch (err) {
    app.innerHTML = `
      <div class="logo">Tmp<span>Drop</span></div>
      <div class="card error-msg">
        <div style="font-size:3rem;margin-bottom:1rem;">⚠️</div>
        <div style="font-weight:600;">Erreur de chargement</div>
        <a href="${BASE}" class="btn btn-primary" style="margin-top:1.5rem;">Réessayer</a>
      </div>
      <div class="footer">TmpDrop · Propulsé par Supabase</div>
    `;
  }
}


function formatSize(bytes) {
  if (bytes < 1024) return bytes + ' o';
  if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' Ko';
  return (bytes / 1048576).toFixed(1) + ' Mo';
}


function esc(s) {
  return String(s).replace(/[&<>"']/g, function(m){
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":"&#39;"}[m];
  });
}
</script>
</body>
</html>
