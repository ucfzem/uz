<style>
:root {
  --bg: #0d0b08;
  --surface: #1a150e;
  --border: rgba(201,168,76,0.15);
  --gold: #c9a84c;
  --gold-dim: #8a7a4a;
  --text: #e8e0d0;
  --text-dim: #8a8270;
  --radius: 12px;
}
* { margin:0; padding:0; box-sizing:border-box; }
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 2rem 1rem 1rem;
}
.container {
  width: 100%;
  max-width: min(92vw, 520px);
}
.logo {
  font-size: clamp(1.5rem, 5vw, 2.5rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 0.15rem;
  text-align: center;
}
.logo span { color: var(--gold); }
.tagline {
  color: var(--text-dim);
  font-size: clamp(0.75rem, 2.5vw, 0.95rem);
  margin-bottom: clamp(1rem, 4vw, 2.5rem);
  text-align: center;
}
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: clamp(1rem, 3vw, 2rem);
  margin-bottom: 1rem;
}
.btn {
  display: block;
  width: 100%;
  padding: clamp(0.75rem, 2.5vw, 1rem);
  border: none;
  border-radius: 8px;
  font-size: clamp(0.9rem, 2.5vw, 1.1rem);
  font-weight: 600;
  cursor: pointer;
  transition: opacity 0.2s;
  text-align: center;
  text-decoration: none;
  -webkit-tap-highlight-color: transparent;
  min-height: 44px;
}
.btn:disabled { opacity: 0.4; cursor: not-allowed; }
.btn-primary { background: var(--gold); color: #0d0b08; }
.btn-primary:hover:not(:disabled) { opacity: 0.9; }
.btn-outline {
  background: transparent;
  border: 1px solid var(--gold);
  color: var(--gold);
}
.progress-bar {
  width: 100%;
  height: 4px;
  background: rgba(201,168,76,0.15);
  border-radius: 2px;
  margin-top: 1rem;
  overflow: hidden;
  display: none;
}
.progress-bar.show { display: block; }
.progress-fill {
  height: 100%;
  width: 0%;
  background: var(--gold);
  border-radius: 2px;
  transition: width 0.3s;
}
.result {
  display: none;
  margin-top: 1rem;
  padding: clamp(0.8rem, 2vw, 1.2rem);
  background: rgba(201,168,76,0.08);
  border-radius: 8px;
  text-align: center;
}
.result.show { display: block; }
.result .link {
  display: block;
  color: var(--gold);
  font-size: clamp(0.8rem, 2vw, 0.9rem);
  word-break: break-all;
  margin: 0.5rem 0;
  padding: 0.5rem;
  background: rgba(0,0,0,0.3);
  border-radius: 6px;
  text-decoration: none;
}
.drop-zone {
  border: 2px dashed var(--border);
  border-radius: var(--radius);
  padding: clamp(1.5rem, 5vw, 2.5rem) 1rem;
  text-align: center;
  cursor: pointer;
  transition: border-color 0.3s, background 0.3s;
  -webkit-tap-highlight-color: transparent;
}
.drop-zone:hover, .drop-zone.dragover { border-color: var(--gold); background: rgba(201,168,76,0.05); }
.drop-zone.has-file { border-color: var(--gold); border-style: solid; }
.drop-zone input { position: absolute; opacity: 0; width: 0; height: 0; pointer-events: none; }
.drop-icon { font-size: clamp(2rem, 8vw, 3rem); margin-bottom: 0.5rem; opacity: 0.5; }
.drop-text { color: var(--text-dim); font-size: clamp(0.8rem, 2.5vw, 1rem); }
.file-info {
  display: none; align-items: center; gap: 0.8rem;
  margin-top: 1rem; padding: 0.8rem;
  background: rgba(201,168,76,0.08); border-radius: 8px;
}
.file-info.show { display: flex; }
.file-info .name { flex:1; font-size: clamp(0.8rem, 2vw, 0.9rem); word-break: break-all; }
.file-info .size { color: var(--text-dim); font-size: clamp(0.7rem, 1.8vw, 0.8rem); white-space: nowrap; }
.result .hint { color: var(--text-dim); font-size: clamp(0.7rem, 1.8vw, 0.8rem); margin-top: 0.5rem; }


/* Share buttons grid */
.share-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.6rem;
  margin: 0.8rem 0;
}
.share-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.35rem;
  padding: 0.7rem 0.3rem;
  border-radius: 10px;
  background: rgba(201,168,76,0.07);
  border: 1px solid var(--border);
  color: var(--text);
  text-decoration: none;
  font-size: clamp(0.6rem, 1.8vw, 0.72rem);
  transition: background 0.2s, border-color 0.2s;
  -webkit-tap-highlight-color: transparent;
}
.share-tile:hover { background: rgba(201,168,76,0.15); border-color: var(--gold); }
.share-tile svg { display: block; }


/* Download page */
.file-card { text-align: center; }
.file-card .icon { font-size: clamp(2.5rem, 8vw, 4rem); margin-bottom: 1rem; }
.file-card .fname {
  font-size: clamp(1rem, 3vw, 1.3rem);
  font-weight: 600;
  margin-bottom: 0.3rem;
  word-break: break-word;
}
.file-card .finfo {
  color: var(--text-dim);
  font-size: clamp(0.8rem, 2vw, 0.95rem);
  margin-bottom: 1.5rem;
}
.file-card .expires {
  color: var(--text-dim);
  font-size: clamp(0.7rem, 1.8vw, 0.85rem);
  margin-top: 1rem;
}
.share-section-title {
  color: var(--text-dim);
  font-size: clamp(0.7rem, 1.8vw, 0.8rem);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin: 1.2rem 0 0.5rem;
}
.copy-row {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 0.6rem;
}
.copy-row .link-box {
  flex: 1;
  background: rgba(0,0,0,0.35);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 0.6rem 0.8rem;
  color: var(--gold);
  font-size: clamp(0.7rem, 1.8vw, 0.8rem);
  word-break: break-all;
  text-decoration: none;
  display: flex;
  align-items: center;
}
.copy-row .copy-btn {
  background: var(--gold);
  color: #0d0b08;
  border: none;
  border-radius: 8px;
  padding: 0 1rem;
  font-weight: 700;
  font-size: 0.85rem;
  cursor: pointer;
  white-space: nowrap;
  min-height: 44px;
  -webkit-tap-highlight-color: transparent;
}
.error-msg {
  color: #e74c3c;
  text-align: center;
  padding: 2rem;
}
.footer {
  margin-top: 2rem;
  text-align: center;
  color: var(--text-dim);
  font-size: clamp(0.65rem, 1.8vw, 0.8rem);
}
@media (min-width: 1400px) {
  body { padding: 3rem; }
  .container { max-width: 600px; }
}
@media (min-width: 2000px) {
  body { padding: 4rem; }
  .container { max-width: 700px; }
  .drop-zone { padding: 4rem 2rem; }
}
@media (max-width: 360px) {
  body { padding: 0.6rem; }
  .card { padding: 0.8rem; }
  .drop-zone { padding: 1rem 0.5rem; }
  .share-grid { grid-template-columns: repeat(4, 1fr); gap: 0.4rem; }
}
</style>
</head>
<body>
<div class="container" id="app"></div>
<script>
const SUPABASE_URL = 'https://vjhcfbwuyebiesxslwhe.supabase.co';
const ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZqaGNmYnd1eWViaWVzeHNsd2hlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODAxNTY5NTcsImV4cCI6MjA5NTczMjk1N30.UaXpJKBVxUslGYOdkXJF-vg_QJC0cCArzlDYPVQVHN4';


const params = new URLSearchParams(window.location.search);
const shareId = params.get('d');
var BASE = window.location.pathname.replace(/\/?$/, '/');


if (shareId && shareId.length > 5) {
  showDownloadPage(shareId);
} else {
  showUploadPage();
}


